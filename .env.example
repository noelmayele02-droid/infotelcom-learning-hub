# Variables d'environnement Supabase / Lovable Cloud
# Copiez ce fichier vers .env et remplissez les valeurs.
# (En production sur Lovable, ces valeurs sont injectées automatiquement.)

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Alias utilisé par certaines configs (même valeur que VITE_SUPABASE_ANON_KEY)
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_PROJECT_ID=xxxxxxxxxxxx

# Côté serveur uniquement (NE JAMAIS exposer côté client)
# SUPABASE_SERVICE_ROLE_KEY=...
# LOVABLE_API_KEY=...